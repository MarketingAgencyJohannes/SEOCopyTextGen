# =====================================================
# SEO Copy Text Generator — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =====================================================

# --- Required: Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Required: Agent 1 (YouTube Channel Scraper) ---
# Create at: https://console.cloud.google.com → Enable YouTube Data API v3
YOUTUBE_API_KEY=AIza...

# --- Required: Agent 2 (SERP Analyzer) ---
# Sign up at: https://serper.dev → free 2,500 searches/month
SERPER_API_KEY=...

# --- Required: Google Drive output ---
# Create a service account in GCP, download JSON key, paste full JSON as single line
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# ID from the Drive folder URL: drive.google.com/drive/folders/{FOLDER_ID}
GOOGLE_DRIVE_FOLDER_ID=...

# --- Optional: Agent 3 (Transcriber) ---
WHISPER_ENABLED=true
# Options: tiny | base | small (large/medium won't fit Railway Hobby 8GB RAM reliably)
WHISPER_MODEL_SIZE=small

# --- Optional: Security ---
# Set a random string — callers must send header: X-API-Key: <value>
# Leave empty to disable auth (not recommended for production)
API_SECRET_KEY=

# --- Optional: Tuning ---
LOG_LEVEL=INFO
SEO_WORD_TARGET=850
SEO_MIN_KEYWORD_DENSITY=0.008
SEO_MAX_KEYWORD_DENSITY=0.012
